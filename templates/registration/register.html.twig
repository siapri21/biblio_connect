{% extends 'base.html.twig' %}

{% block title %}Inscription — Biblio Connect{% endblock %}

{% block body %}
    {% include '_partials/_nav.html.twig' %}

    <main class="container auth-page">
        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="flash flash--error" role="alert">{{ flash_error }}</div>
        {% endfor %}

        <h1 class="page-title">Créer un compte</h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, { attr: { class: 'form-card' } }) }}
            {{ form_row(registrationForm.email) }}
            {{ form_row(registrationForm.plainPassword.first) }}
            {{ form_row(registrationForm.plainPassword.second) }}
            {{ form_row(registrationForm.agreeTerms) }}

            <button type="submit" class="btn btn--primary btn--block">S’inscrire</button>
        {{ form_end(registrationForm) }}

        <p class="auth-page__footer"><a href="{{ path('app_login') }}">Déjà un compte ? Connexion</a></p>
    </main>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Inscription — Biblio Connect{% endblock %}

{% block body %}
    {% include '_partials/_nav.html.twig' %}

    <main class="container auth-page auth-page--wide">
        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="flash flash--error" role="alert">{{ flash_error }}</div>
        {% endfor %}

        <header class="auth-page__header-block">
            <h1 class="page-title">Créer un compte</h1>
            <div class="auth-register-notice" role="note">
                <p class="auth-register-notice__title">Compte usager</p>
                <p>
                    Ce formulaire crée un <strong>nouveau</strong> compte avec un <strong>nouvel e-mail</strong> (rôle usager uniquement).
                    Les comptes <strong>bibliothécaire</strong> et <strong>administrateur</strong> ne s’obtiennent pas ici.
                </p>
                <p class="auth-register-notice__important">
                    <strong>Important :</strong> si vous avez chargé les données de démo, les adresses comme
                    <code>admin@biblio-connect.local</code> existent déjà — vous ne pouvez pas les « réinscrire ».
                    Allez sur <a href="{{ path('app_login') }}">Connexion</a> et utilisez ce compte avec son mot de passe.
                </p>
            </div>
        </header>

        {% if redirect_path is defined and redirect_path %}
            <p class="flash flash--info">
                {% if from_action == 'reserve' %}
                    Créez un compte pour <strong>réserver</strong> cet ouvrage.
                {% elseif from_action == 'favorite' %}
                    Créez un compte pour ajouter ce livre à vos <strong>favoris</strong>.
                {% else %}
                    Créez un compte pour continuer.
                {% endif %}
            </p>
        {% endif %}

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, { attr: { class: 'form-card' } }) }}
            {% if redirect_path is defined and redirect_path %}
                <input type="hidden" name="redirect" value="{{ redirect_path }}">
            {% endif %}
            {{ form_row(registrationForm.email) }}
            {{ form_row(registrationForm.plainPassword.first) }}
            {{ form_row(registrationForm.plainPassword.second) }}
            {{ form_row(registrationForm.agreeTerms) }}

            <button type="submit" class="btn btn--primary btn--block">S’inscrire</button>
        {{ form_end(registrationForm) }}

        <p class="auth-page__footer">
            {% set login_params = {} %}
            {% if redirect_path is defined and redirect_path %}{% set login_params = login_params|merge({ redirect: redirect_path }) %}{% endif %}
            {% if from_action is defined and from_action %}{% set login_params = login_params|merge({ from: from_action }) %}{% endif %}
            <a href="{{ path('app_login', login_params) }}">Déjà un compte ? Connexion</a>
        </p>
    </main>
{% endblock %}

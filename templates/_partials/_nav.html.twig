<header class="landing-header" role="banner">
    <div class="container landing-header__inner landing-header__inner--full">
        <a href="{{ path('app_home') }}" class="landing-header__logo" aria-label="Biblio Connect — accueil">
            <img src="{{ asset('images/logo-biblio.svg') }}" alt="" width="132" height="40" class="landing-header__logo-img" decoding="async">
        </a>

        <nav class="landing-header__nav" aria-label="Navigation principale">
            <a href="{{ path('app_home') }}" class="landing-header__link {{ app.request.attributes.get('_route') == 'app_home' ? 'landing-header__link--active' : '' }}">Accueil</a>
            <a href="{{ path('app_catalog') }}" class="landing-header__link {{ app.request.attributes.get('_route') == 'app_catalog' ? 'landing-header__link--active' : '' }}">Catalogue</a>
            <a href="{{ path('app_contact') }}" class="landing-header__link {{ app.request.attributes.get('_route') == 'app_contact' ? 'landing-header__link--active' : '' }}">Contact</a>
            <a href="{{ path('app_help') }}" class="landing-header__link {{ app.request.attributes.get('_route') == 'app_help' ? 'landing-header__link--active' : '' }}">Aide</a>
        </nav>

        <form class="landing-header__search" method="get" action="{{ path('app_catalog') }}" role="search">
            <label for="nav-search-q" class="visually-hidden">Rechercher dans le catalogue</label>
            <input
                type="search"
                id="nav-search-q"
                name="q"
                class="landing-header__search-input"
                placeholder="Titre, auteur, catégorie…"
                value="{{ app.request.query.get('q')|default('')|e('html_attr') }}"
                autocomplete="off"
                maxlength="200"
            >
            <button type="submit" class="landing-header__search-btn">Rechercher</button>
        </form>

        <div class="landing-header__actions{% if app.user %} landing-header__actions--logged{% endif %}">
            {% if app.user %}
                <a href="{{ path('app_favorites') }}" class="landing-header__icon-btn" title="Mes favoris" aria-label="Mes favoris">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                </a>
                <div class="landing-header__pro-links">
                    <a href="{{ path('app_user_dashboard') }}" class="landing-header__link landing-header__link--compact">Mon espace</a>
                    {% if is_granted('ROLE_LIBRARIAN') %}
                        <a href="{{ path('app_librarian_dashboard') }}" class="landing-header__link landing-header__link--compact">Bibliothèque</a>
                    {% endif %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_dashboard') }}" class="landing-header__link landing-header__link--compact">Admin</a>
                    {% endif %}
                </div>
                <div class="landing-header__session">
                    <span class="landing-header__user" title="{{ app.user.userIdentifier }}">Hey, {{ app.user.displayName }}</span>
                    <a href="{{ path('app_logout') }}" class="landing-header__link landing-header__link--compact landing-header__logout">Déconnexion</a>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="landing-header__link">Connexion</a>
                <a href="{{ path('app_register') }}" class="btn btn--landing-cta">S’inscrire</a>
            {% endif %}
        </div>
    </div>
</header>

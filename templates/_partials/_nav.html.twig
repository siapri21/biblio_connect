<nav class="site-nav">
    <div class="site-nav__inner container">
        <a href="{{ path('app_home') }}" class="site-nav__brand">Biblio Connect</a>

        <form class="site-nav__search" method="get" action="{{ path('app_catalog') }}" role="search">
            <label for="nav-search-q" class="visually-hidden">Rechercher dans le catalogue</label>
            <input
                type="search"
                id="nav-search-q"
                name="q"
                class="site-nav__search-input"
                placeholder="Titre, auteur, catégorie…"
                value="{{ app.request.query.get('q')|default('')|e('html_attr') }}"
                autocomplete="off"
                maxlength="200"
            >
            <button type="submit" class="site-nav__search-btn">Rechercher</button>
        </form>

        <div class="site-nav__links">
            <a href="{{ path('app_catalog') }}">Catalogue</a>
            {% if app.user %}
                <a href="{{ path('app_favorites') }}" class="site-nav__favorites" title="Mes favoris" aria-label="Mes favoris">
                    <span class="visually-hidden">Mes favoris</span>
                    <svg class="site-nav__favorites-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                </a>
                <a href="{{ path('app_user_dashboard') }}">Mon espace</a>
                {% if is_granted('ROLE_LIBRARIAN') %}
                    <a href="{{ path('app_librarian_dashboard') }}">Bibliothèque</a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}">Admin</a>
                {% endif %}
                <span class="site-nav__user">{{ app.user.userIdentifier }}</span>
                <a href="{{ path('app_logout') }}">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}">Connexion</a>
                <a href="{{ path('app_register') }}" class="btn btn--nav">Inscription</a>
            {% endif %}
        </div>
    </div>
</nav>

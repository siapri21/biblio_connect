{% extends 'base.html.twig' %}

{% block title %}Nouvel ouvrage{% endblock %}

{% block body %}
    {% include '_partials/_nav.html.twig' %}
    <main class="container dashboard-page">
        <h1 class="page-title">Ajouter un ouvrage</h1>
        <form method="post" class="form-card">
            <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">
            <p><label>Titre <input name="title" required class="input"></label></p>
            <p><label>Auteur <input name="author" required class="input"></label></p>
            <p><label>Catégorie <input name="category" required class="input"></label></p>
            <p><label>Langue <input name="language" required class="input"></label></p>
            <p><label>Stock <input name="stock" type="number" min="0" value="1" required class="input"></label></p>
            <p>
                <label>Bibliothèque de rattachement
                    <select name="library_id" class="input" required>
                        {% for lib in libraries %}
                            <option value="{{ lib.id }}">{{ lib.label }}</option>
                        {% endfor %}
                    </select>
                </label>
            </p>
            <p><label>Description <textarea name="description" rows="4" class="input"></textarea></label></p>
            <button type="submit" class="btn btn--primary">Enregistrer</button>
        </form>
        <p class="auth-page__footer"><a href="{{ path('app_librarian_dashboard') }}">Retour</a></p>
    </main>
{% endblock %}
